/-- Minimal polynomial of α (degree 3) as `Polynomial ℂ`. -/
noncomputable def α_42_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 3 +
    Polynomial.C (-520435526440845312) +
    Polynomial.C (-6374982426624) * Polynomial.X +
    Polynomial.C 344688 * Polynomial.X ^ 2

lemma α_42_minpoly_natDegree : α_42_minpoly.natDegree = 3 := by
  unfold α_42_minpoly
  compute_degree!

lemma α_42_minpoly_degree_ne_zero : α_42_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_42_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_42_minpoly_natDegree]
  decide

/-- α is some root of the degree-3 minimal polynomial in ℂ. -/
noncomputable def α_42 : ℂ :=
  (IsAlgClosed.exists_root α_42_minpoly α_42_minpoly_degree_ne_zero).choose

lemma α_42_isRoot : Polynomial.IsRoot α_42_minpoly α_42 :=
  (IsAlgClosed.exists_root α_42_minpoly α_42_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_42_is_root :
    α_42 ^ 3 +
      (-520435526440845312) +
      (-6374982426624) * α_42 +
      344688 * α_42 ^ 2 = 0 := by
  have h := α_42_isRoot
  unfold Polynomial.IsRoot α_42_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


