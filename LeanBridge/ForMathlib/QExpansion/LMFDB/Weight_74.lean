/-- Minimal polynomial of α (degree 5) as `Polynomial ℂ`. -/
noncomputable def α_74_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 5 +
    Polynomial.C 113628227457643966226006850359168010340399423074336768 +
    Polynomial.C 11802708847432637761332792635527627366465536 * Polynomial.X +
    Polynomial.C (-1377989142595747748686715833810944) * Polynomial.X ^ 2 +
    Polynomial.C (-19817164982845968703488) * Polynomial.X ^ 3 +
    Polynomial.C 92089333488 * Polynomial.X ^ 4

lemma α_74_minpoly_natDegree : α_74_minpoly.natDegree = 5 := by
  unfold α_74_minpoly
  compute_degree!

lemma α_74_minpoly_degree_ne_zero : α_74_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_74_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_74_minpoly_natDegree]
  decide

/-- α is some root of the degree-5 minimal polynomial in ℂ. -/
noncomputable def α_74 : ℂ :=
  (IsAlgClosed.exists_root α_74_minpoly α_74_minpoly_degree_ne_zero).choose

lemma α_74_isRoot : Polynomial.IsRoot α_74_minpoly α_74 :=
  (IsAlgClosed.exists_root α_74_minpoly α_74_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_74_is_root :
    α_74 ^ 5 +
      113628227457643966226006850359168010340399423074336768 +
      11802708847432637761332792635527627366465536 * α_74 +
      (-1377989142595747748686715833810944) * α_74 ^ 2 +
      (-19817164982845968703488) * α_74 ^ 3 +
      92089333488 * α_74 ^ 4 = 0 := by
  have h := α_74_isRoot
  unfold Polynomial.IsRoot α_74_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


