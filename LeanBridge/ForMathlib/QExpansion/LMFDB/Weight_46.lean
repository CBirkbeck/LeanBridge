/-- Minimal polynomial of α (degree 3) as `Polynomial ℂ`. -/
noncomputable def α_46_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 3 +
    Polynomial.C 135250282417024401408 +
    Polynomial.C (-44544640241664) * Polynomial.X +
    Polynomial.C (-3814272) * Polynomial.X ^ 2

lemma α_46_minpoly_natDegree : α_46_minpoly.natDegree = 3 := by
  unfold α_46_minpoly
  compute_degree!

lemma α_46_minpoly_degree_ne_zero : α_46_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_46_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_46_minpoly_natDegree]
  decide

/-- α is some root of the degree-3 minimal polynomial in ℂ. -/
noncomputable def α_46 : ℂ :=
  (IsAlgClosed.exists_root α_46_minpoly α_46_minpoly_degree_ne_zero).choose

lemma α_46_isRoot : Polynomial.IsRoot α_46_minpoly α_46 :=
  (IsAlgClosed.exists_root α_46_minpoly α_46_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_46_is_root :
    α_46 ^ 3 +
      135250282417024401408 +
      (-44544640241664) * α_46 +
      (-3814272) * α_46 ^ 2 = 0 := by
  have h := α_46_isRoot
  unfold Polynomial.IsRoot α_46_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


