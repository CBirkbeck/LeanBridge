/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-148 modular form `f` whose first 13
q-coefficients match the LMFDB-published values for `1.148.a.{a..}` is equal to our
explicit construction `lmfdb_1_148_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_148_a_orbit (f : ModularForm 𝒮ℒ 148)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_148)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ( / ) * α_148 + ((-( / ))) * α_148 ^ 2 + ((-( / ))) * α_148 ^ 3 + ( / ) * α_148 ^ 4 + ( / ) * α_148 ^ 5 + ((-( / ))) * α_148 ^ 6 + ((-( / ))) * α_148 ^ 7 + ( / ) * α_148 ^ 8 + ( / ) * α_148 ^ 9 + ((-( / ))) * α_148 ^ 10 + ((-( / ))) * α_148 ^ 11)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-178405961588244985132285746181186892047843328) + 1 * α_148 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ((-( / ))) * α_148 + ( / ) * α_148 ^ 2 + ( / ) * α_148 ^ 3 + ((-( / ))) * α_148 ^ 4 + ((-( / ))) * α_148 ^ 5 + ( / ) * α_148 ^ 6 + ( / ) * α_148 ^ 7 + ((-( / ))) * α_148 ^ 8 + ((-( / ))) * α_148 ^ 9 + ( / ) * α_148 ^ 10 + ( / ) * α_148 ^ 11)
    (h_6 : (PowerSeries.coeff (R := ℂ) 6) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ((-( / ))) * α_148 + ( / ) * α_148 ^ 2 + ( / ) * α_148 ^ 3 + ((-( / ))) * α_148 ^ 4 + ((-( / ))) * α_148 ^ 5 + ( / ) * α_148 ^ 6 + ( / ) * α_148 ^ 7 + ((-( / ))) * α_148 ^ 8 + ((-( / ))) * α_148 ^ 9 + ( / ) * α_148 ^ 10 + ( / ) * α_148 ^ 11)
    (h_7 : (PowerSeries.coeff (R := ℂ) 7) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ( / ) * α_148 + ( / ) * α_148 ^ 2 + ( / ) * α_148 ^ 3 + ((-( / ))) * α_148 ^ 4 + ((-( / ))) * α_148 ^ 5 + ( / ) * α_148 ^ 6 + ( / ) * α_148 ^ 7 + ((-( / ))) * α_148 ^ 8 + ((-( / ))) * α_148 ^ 9 + ( / ) * α_148 ^ 10 + ( / ) * α_148 ^ 11)
    (h_8 : (PowerSeries.coeff (R := ℂ) 8) (qExpansion 1 (f : ℍ → ℂ)) = (-356811923176489970264571492362373784095686656) * α_148 + 1 * α_148 ^ 3)
    (h_9 : (PowerSeries.coeff (R := ℂ) 9) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ( / ) * α_148 + ((-( / ))) * α_148 ^ 2 + ((-( / ))) * α_148 ^ 3 + ( / ) * α_148 ^ 4 + ( / ) * α_148 ^ 5 + ((-( / ))) * α_148 ^ 6 + ((-( / ))) * α_148 ^ 7 + ( / ) * α_148 ^ 8 + ( / ) * α_148 ^ 9 + ((-( / ))) * α_148 ^ 10 + ((-( / ))) * α_148 ^ 11)
    (h_10 : (PowerSeries.coeff (R := ℂ) 10) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ( / ) * α_148 + ((-( / ))) * α_148 ^ 2 + ((-( / ))) * α_148 ^ 3 + ( / ) * α_148 ^ 4 + ( / ) * α_148 ^ 5 + ((-( / ))) * α_148 ^ 6 + ((-( / ))) * α_148 ^ 7 + ( / ) * α_148 ^ 8 + ( / ) * α_148 ^ 9 + ((-( / ))) * α_148 ^ 10 + ((-( / ))) * α_148 ^ 11)
