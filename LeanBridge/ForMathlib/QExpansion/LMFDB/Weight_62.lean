/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-62 modular form `f` whose first 6
q-coefficients match the LMFDB-published values for `1.62.a.{a..}` is equal to our
explicit construction `lmfdb_1_62_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_62_a_orbit (f : ModularForm 𝒮ℒ 62)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_62)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ((-(4655502295918311553500 / 13402613))) + (1049101247225 / 1802032) * α_62 + (6202375 / 41172827136) * α_62 ^ 2 + ((-(1 / 7905182810112))) * α_62 ^ 3)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-2305843009213693952) + 1 * α_62 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = (91289663070569083276258590 / 326893) + ((-(47212959768005 / 10988))) * α_62 + ((-(10135188585 / 83684608))) * α_62 ^ 2 + (5 / 5355814912) * α_62 ^ 3) :
    f = lmfdb_1_62_a_orbit := by
  apply ModularForm.eq_of_sturm_bound
  intro i hi
  have : i ≤ 5 := by omega
  interval_cases i
  · rw [h_0, lmfdb_1_62_a_orbit_qExpansion_coeff_0]
  · rw [h_1, lmfdb_1_62_a_orbit_qExpansion_coeff_1]
  · rw [h_2, lmfdb_1_62_a_orbit_qExpansion_coeff_2]
  · rw [h_3, lmfdb_1_62_a_orbit_qExpansion_coeff_3]
  · rw [h_4, lmfdb_1_62_a_orbit_qExpansion_coeff_4]
  · rw [h_5, lmfdb_1_62_a_orbit_qExpansion_coeff_5]


