/-- Minimal polynomial of α (degree 4) as `Polynomial ℂ`. -/
noncomputable def α_62_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 4 +
    Polynomial.C 3583176547297492565952659077522784256 +
    Polynomial.C 2540887466526178560442368000 * Polynomial.X +
    Polynomial.C (-6156169255669690368) * Polynomial.X ^ 2 +
    Polynomial.C (-1146312000) * Polynomial.X ^ 3

lemma α_62_minpoly_natDegree : α_62_minpoly.natDegree = 4 := by
  unfold α_62_minpoly
  compute_degree!

lemma α_62_minpoly_degree_ne_zero : α_62_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_62_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_62_minpoly_natDegree]
  decide

/-- α is some root of the degree-4 minimal polynomial in ℂ. -/
noncomputable def α_62 : ℂ :=
  (IsAlgClosed.exists_root α_62_minpoly α_62_minpoly_degree_ne_zero).choose

lemma α_62_isRoot : Polynomial.IsRoot α_62_minpoly α_62 :=
  (IsAlgClosed.exists_root α_62_minpoly α_62_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_62_is_root :
    α_62 ^ 4 +
      3583176547297492565952659077522784256 +
      2540887466526178560442368000 * α_62 +
      (-6156169255669690368) * α_62 ^ 2 +
      (-1146312000) * α_62 ^ 3 = 0 := by
  have h := α_62_isRoot
  unfold Polynomial.IsRoot α_62_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


