/-- Minimal polynomial of α (degree 3) as `Polynomial ℂ`. -/
noncomputable def α_36_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 3 +
    Polynomial.C (-1467625047588864) +
    Polynomial.C (-59208339456) * Polynomial.X +
    Polynomial.C (-139656) * Polynomial.X ^ 2

lemma α_36_minpoly_natDegree : α_36_minpoly.natDegree = 3 := by
  unfold α_36_minpoly
  compute_degree!

lemma α_36_minpoly_degree_ne_zero : α_36_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_36_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_36_minpoly_natDegree]
  decide

/-- α is some root of the degree-3 minimal polynomial in ℂ. -/
noncomputable def α_36 : ℂ :=
  (IsAlgClosed.exists_root α_36_minpoly α_36_minpoly_degree_ne_zero).choose

lemma α_36_isRoot : Polynomial.IsRoot α_36_minpoly α_36 :=
  (IsAlgClosed.exists_root α_36_minpoly α_36_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_36_is_root :
    α_36 ^ 3 +
      (-1467625047588864) +
      (-59208339456) * α_36 +
      (-139656) * α_36 ^ 2 = 0 := by
  have h := α_36_isRoot
  unfold Polynomial.IsRoot α_36_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


