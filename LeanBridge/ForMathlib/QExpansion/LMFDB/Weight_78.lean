    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_78)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ((-(5174469326298061072647352156269427388149182244780 / 1124567549173708319671680892833))) + ((-(79770762029767301636299956091084480293197 / 891528131886872763362942891040768))) * α_78 + (8204649664155624871242447858692435 / 319631085386731922825712103151414280192) * α_78 ^ 2 + (130819406114508241628727995051 / 133539310425893503501199910999835674949976064) * α_78 ^ 3 + ((-(82647855828912145 / 6409886900442888168057595727992112397598851072))) * α_78 ^ 4 + ((-(8104264459 / 4922793139540138113068233519097942321355917623296))) * α_78 ^ 5)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-151115727451828646838272) + 1 * α_78 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = ((-(11280633027866806963925986999382175257886598293698147814 / 4030708061554510106350110727))) + ((-(187154496429705675799566569625526035167242610861 / 8254890110063636697805026768896))) * α_78 + (16898709630671426634944319426876321791871 / 540992478253130494627350234326368256) * α_78 ^ 2 + (1148403533548349162126357957180141 / 4431810381849645011987253119601608753152) * α_78 ^ 3 + ((-(3534196632002381779389 / 70908966109594320191796049913625740050432))) * α_78 ^ 4 + ((-(8084241046117 / 18152695324056145969099788777888189452910592))) * α_78 ^ 5)
    (h_6 : (PowerSeries.coeff (R := ℂ) 6) (qExpansion 1 (f : ℍ → ℂ)) = ((-(1086570864278917504281727104224578642705247253609973364555776 / 374855849724569439890560297611))) + ((-(994545559515798603045214300985156255499379640020 / 36276372553990590957150996543))) * α_78 + (27627313073520196898084895757334618195417 / 863667877765407989507850925695744) * α_78 ^ 2 + (5862684722408192592418235972858305 / 21225501763962666750144944349898604544) * α_78 ^ 3 + ((-(51143669255476309013363 / 1018824084670208004006957328795133018112))) * α_78 ^ 4 + ((-(351087217840865 / 782456897026719747077343228514662157910016))) * α_78 ^ 5) :
