    Polynomial.C (-625552701032748610916352) * Polynomial.X ^ 4 +
    Polynomial.C (-264721893120) * Polynomial.X ^ 5

lemma α_78_minpoly_natDegree : α_78_minpoly.natDegree = 6 := by
  unfold α_78_minpoly
  compute_degree!

lemma α_78_minpoly_degree_ne_zero : α_78_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_78_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_78_minpoly_natDegree]
  decide

/-- α is some root of the degree-6 minimal polynomial in ℂ. -/
noncomputable def α_78 : ℂ :=
  (IsAlgClosed.exists_root α_78_minpoly α_78_minpoly_degree_ne_zero).choose

lemma α_78_isRoot : Polynomial.IsRoot α_78_minpoly α_78 :=
  (IsAlgClosed.exists_root α_78_minpoly α_78_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_78_is_root :
    α_78 ^ 6 +
      (-1760725869560168758370165898745109881407673355007925193621425675567104) +
      (-13858265616170285441123883155767378501080128760239483781120) * α_78 +
