      (-625552701032748610916352) * α_78 ^ 4 +
      (-264721893120) * α_78 ^ 5 = 0 := by
  have h := α_78_isRoot
  unfold Polynomial.IsRoot α_78_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
