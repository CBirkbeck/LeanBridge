/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-60 modular form `f` whose first 6
q-coefficients match the LMFDB-published values for `1.60.a.{a..}` is equal to our
explicit construction `lmfdb_1_60_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_60_a_orbit (f : ModularForm 𝒮ℒ 60)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_60)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ((-(7628976017956720724425588 / 51560765613))) + ((-(826921959594102775 / 2671338713664))) * α_60 + (57168801404051 / 121647108067688448) * α_60 ^ 2 + (40257529 / 176469404770193375232) * α_60 ^ 3 + ((-(1 / 5445341632908824150016))) * α_60 ^ 4)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-576460752303423488) + 1 * α_60 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = ((-(679276420725026107775505486562866 / 486962786345))) + ((-(278180104979341207030471 / 1558280916304))) * α_60 + (176955697240372266507 / 31913593165905920) * α_60 ^ 2 + ((-(5615918111 / 13730890504994816))) * α_60 ^ 3 + ((-(175863 / 65359038803775324160))) * α_60 ^ 4) :
    f = lmfdb_1_60_a_orbit := by
  apply ModularForm.eq_of_sturm_bound
  intro i hi
  have : i ≤ 5 := by omega
  interval_cases i
  · rw [h_0, lmfdb_1_60_a_orbit_qExpansion_coeff_0]
  · rw [h_1, lmfdb_1_60_a_orbit_qExpansion_coeff_1]
  · rw [h_2, lmfdb_1_60_a_orbit_qExpansion_coeff_2]
  · rw [h_3, lmfdb_1_60_a_orbit_qExpansion_coeff_3]
  · rw [h_4, lmfdb_1_60_a_orbit_qExpansion_coeff_4]
  · rw [h_5, lmfdb_1_60_a_orbit_qExpansion_coeff_5]


end LeanBridge.QExpansion.LMFDB.W60