/-- Minimal polynomial of α (degree 5) as `Polynomial ℂ`. -/
noncomputable def α_60_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 5 +
    Polynomial.C 263222216157060824115203098902237248565018624 +
    Polynomial.C 810634763334812972416233648439689216 * Polynomial.X +
    Polynomial.C (-736010060393513697870348288) * Polynomial.X ^ 2 +
    Polynomial.C (-2209450184054433792) * Polynomial.X ^ 3 +
    Polynomial.C 449691864 * Polynomial.X ^ 4

lemma α_60_minpoly_natDegree : α_60_minpoly.natDegree = 5 := by
  unfold α_60_minpoly
  compute_degree!

lemma α_60_minpoly_degree_ne_zero : α_60_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_60_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_60_minpoly_natDegree]
  decide

/-- α is some root of the degree-5 minimal polynomial in ℂ. -/
noncomputable def α_60 : ℂ :=
  (IsAlgClosed.exists_root α_60_minpoly α_60_minpoly_degree_ne_zero).choose

lemma α_60_isRoot : Polynomial.IsRoot α_60_minpoly α_60 :=
  (IsAlgClosed.exists_root α_60_minpoly α_60_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_60_is_root :
    α_60 ^ 5 +
      263222216157060824115203098902237248565018624 +
      810634763334812972416233648439689216 * α_60 +
      (-736010060393513697870348288) * α_60 ^ 2 +
      (-2209450184054433792) * α_60 ^ 3 +
      449691864 * α_60 ^ 4 = 0 := by
  have h := α_60_isRoot
  unfold Polynomial.IsRoot α_60_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


