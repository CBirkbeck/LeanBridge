/-- Minimal polynomial of α (degree 3) as `Polynomial ℂ`. -/
noncomputable def α_40_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 3 +
    Polynomial.C 213542160549543936 +
    Polynomial.C (-810051757056) * Polynomial.X +
    Polynomial.C (-548856) * Polynomial.X ^ 2

lemma α_40_minpoly_natDegree : α_40_minpoly.natDegree = 3 := by
  unfold α_40_minpoly
  compute_degree!

lemma α_40_minpoly_degree_ne_zero : α_40_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_40_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_40_minpoly_natDegree]
  decide

/-- α is some root of the degree-3 minimal polynomial in ℂ. -/
noncomputable def α_40 : ℂ :=
  (IsAlgClosed.exists_root α_40_minpoly α_40_minpoly_degree_ne_zero).choose

lemma α_40_isRoot : Polynomial.IsRoot α_40_minpoly α_40 :=
  (IsAlgClosed.exists_root α_40_minpoly α_40_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_40_is_root :
    α_40 ^ 3 +
      213542160549543936 +
      (-810051757056) * α_40 +
      (-548856) * α_40 ^ 2 = 0 := by
  have h := α_40_isRoot
  unfold Polynomial.IsRoot α_40_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


