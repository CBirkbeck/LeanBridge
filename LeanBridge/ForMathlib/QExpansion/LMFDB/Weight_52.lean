/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-52 modular form `f` whose first 5
q-coefficients match the LMFDB-published values for `1.52.a.{a..}` is equal to our
explicit construction `lmfdb_1_52_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_52_a_orbit (f : ModularForm 𝒮ℒ 52)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_52)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = (68520858537679740 / 90041) + (1271597110 / 12863) * α_52 + ((-(280415 / 829817856))) * α_52 ^ 2 + ((-(1 / 59746885632))) * α_52 ^ 3)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-2251799813685248) + 1 * α_52 ^ 2) :
    f = lmfdb_1_52_a_orbit := by
  apply ModularForm.eq_of_sturm_bound
  intro i hi
  have : i ≤ 4 := by omega
  interval_cases i
  · rw [h_0, lmfdb_1_52_a_orbit_qExpansion_coeff_0]
  · rw [h_1, lmfdb_1_52_a_orbit_qExpansion_coeff_1]
  · rw [h_2, lmfdb_1_52_a_orbit_qExpansion_coeff_2]
  · rw [h_3, lmfdb_1_52_a_orbit_qExpansion_coeff_3]
  · rw [h_4, lmfdb_1_52_a_orbit_qExpansion_coeff_4]


end LeanBridge.QExpansion.LMFDB.W52