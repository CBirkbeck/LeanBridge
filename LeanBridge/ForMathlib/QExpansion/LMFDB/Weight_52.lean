/-- Minimal polynomial of α (degree 4) as `Polynomial ℂ`. -/
noncomputable def α_52_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 4 +
    Polynomial.C 4615876968087578049834569957376 +
    Polynomial.C 269568678949709508771840 * Polynomial.X +
    Polynomial.C (-7956172284567552) * Polynomial.X ^ 2 +
    Polynomial.C (-32756040) * Polynomial.X ^ 3

lemma α_52_minpoly_natDegree : α_52_minpoly.natDegree = 4 := by
  unfold α_52_minpoly
  compute_degree!

lemma α_52_minpoly_degree_ne_zero : α_52_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_52_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_52_minpoly_natDegree]
  decide

/-- α is some root of the degree-4 minimal polynomial in ℂ. -/
noncomputable def α_52 : ℂ :=
  (IsAlgClosed.exists_root α_52_minpoly α_52_minpoly_degree_ne_zero).choose

lemma α_52_isRoot : Polynomial.IsRoot α_52_minpoly α_52 :=
  (IsAlgClosed.exists_root α_52_minpoly α_52_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_52_is_root :
    α_52 ^ 4 +
      4615876968087578049834569957376 +
      269568678949709508771840 * α_52 +
      (-7956172284567552) * α_52 ^ 2 +
      (-32756040) * α_52 ^ 3 = 0 := by
  have h := α_52_isRoot
  unfold Polynomial.IsRoot α_52_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


