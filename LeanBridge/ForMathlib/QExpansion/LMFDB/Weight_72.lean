      (-9002758724278005040128) * α_72 ^ 4 +
      (-66157336440) * α_72 ^ 5 = 0 := by
  have h := α_72_isRoot
  unfold Polynomial.IsRoot α_72_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
