/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-72 modular form `f` whose first 7
q-coefficients match the LMFDB-published values for `1.72.a.{a..}` is equal to our
explicit construction `lmfdb_1_72_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_72_a_orbit (f : ModularForm 𝒮ℒ 72)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_72)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = (9192657193170721011420054536011412708020233860 / 184139574313540977597749070123) + (3398689643134176030000655788131444496911 / 2262707089164791532721140573671424) * α_72 + ((-(129151018404657686766872385296058035 / 889732630773022667330476011816782659584))) * α_72 ^ 2 + ((-(3148977978780220081729698451 / 5466517283469451268078444616602312660484096))) * α_72 ^ 3 + (56333322028747326505 / 2099142636852269286942122732775288061625892864) * α_72 ^ 4 + ((-(1725241141 / 50379423284454462886610945586606913479021428736))) * α_72 ^ 5)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-2361183241434822606848) + 1 * α_72 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = ((-(741453113060686327818585535619320099274314237140127734 / 56833201948623758517823787075))) + (49264511477353976328906998961060023179910030869 / 58197198795390728722251557964800) * α_72 + (68778009372306429207303260736633706487349 / 7628023240509453595082956205562265600) * α_72 ^ 2 + ((-(6154361798397467598337709135399993 / 15622191596563360962729894308991519948800))) * α_72 ^ 3 + ((-(2904403576165513211225943 / 1999640524360110203229426471550914553446400))) * α_72 ^ 4 + (679058874948121 / 15997124194880881625835411772407316427571200) * α_72 ^ 5)
    (h_6 : (PowerSeries.coeff (R := ℂ) 6) (qExpansion 1 (f : ℍ → ℂ)) = (8768409574446618586036788868123955602243618699376328704 / 61379858104513659199249690041) + (3886974298069598257449565034333785665727956740 / 184139574313540977597749070123) * α_72 + (1225428173811046127966532263187551019167 / 565676772291197883180285143417856) * α_72 ^ 2 + ((-(444899992032984626909354062012865 / 3475518088957119794259671921159307264))) * α_72 ^ 3 + ((-(1180249076050111931955949 / 1334598946159534000995714017725173989376))) * α_72 ^ 4 + (787011699730345 / 32030374707828816023897136425404175745024) * α_72 ^ 5) :
    f = lmfdb_1_72_a_orbit := by
  apply ModularForm.eq_of_sturm_bound
  intro i hi
  have : i ≤ 6 := by omega
  interval_cases i
  · rw [h_0, lmfdb_1_72_a_orbit_qExpansion_coeff_0]
