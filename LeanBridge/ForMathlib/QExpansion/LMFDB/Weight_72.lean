    Polynomial.C (-9002758724278005040128) * Polynomial.X ^ 4 +
    Polynomial.C (-66157336440) * Polynomial.X ^ 5

lemma α_72_minpoly_natDegree : α_72_minpoly.natDegree = 6 := by
  unfold α_72_minpoly
  compute_degree!

lemma α_72_minpoly_degree_ne_zero : α_72_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_72_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_72_minpoly_natDegree]
  decide

/-- α is some root of the degree-6 minimal polynomial in ℂ. -/
noncomputable def α_72 : ℂ :=
  (IsAlgClosed.exists_root α_72_minpoly α_72_minpoly_degree_ne_zero).choose

lemma α_72_isRoot : Polynomial.IsRoot α_72_minpoly α_72 :=
  (IsAlgClosed.exists_root α_72_minpoly α_72_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_72_is_root :
    α_72 ^ 6 +
      4171558450151166049898984513691112295971825841981859595680743424 +
      (-841390377086653548715101191193731810412939033433866240) * α_72 +
