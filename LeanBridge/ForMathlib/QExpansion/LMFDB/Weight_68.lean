/-- Minimal polynomial of α (degree 5) as `Polynomial ℂ`. -/
noncomputable def α_68_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 5 +
    Polynomial.C (-224135116306806567372209572838489759238644853374976) +
    Polynomial.C 50978026392314038029857853615859298205696 * Polynomial.X +
    Polynomial.C 1360506199877236618906967212032 * Polynomial.X ^ 2 +
    Polynomial.C (-528742419683384143872) * Polynomial.X ^ 3 +
    Polynomial.C (-5554901256) * Polynomial.X ^ 4

lemma α_68_minpoly_natDegree : α_68_minpoly.natDegree = 5 := by
  unfold α_68_minpoly
  compute_degree!

lemma α_68_minpoly_degree_ne_zero : α_68_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_68_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_68_minpoly_natDegree]
  decide

/-- α is some root of the degree-5 minimal polynomial in ℂ. -/
noncomputable def α_68 : ℂ :=
  (IsAlgClosed.exists_root α_68_minpoly α_68_minpoly_degree_ne_zero).choose

lemma α_68_isRoot : Polynomial.IsRoot α_68_minpoly α_68 :=
  (IsAlgClosed.exists_root α_68_minpoly α_68_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_68_is_root :
    α_68 ^ 5 +
      (-224135116306806567372209572838489759238644853374976) +
      50978026392314038029857853615859298205696 * α_68 +
      1360506199877236618906967212032 * α_68 ^ 2 +
      (-528742419683384143872) * α_68 ^ 3 +
      (-5554901256) * α_68 ^ 4 = 0 := by
  have h := α_68_isRoot
  unfold Polynomial.IsRoot α_68_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


