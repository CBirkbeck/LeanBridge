/-- Minimal polynomial of α (degree 2) as `Polynomial ℂ`. -/
noncomputable def α_32_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 2 +
    Polynomial.C (-2235350016) +
    Polynomial.C (-39960) * Polynomial.X

lemma α_32_minpoly_natDegree : α_32_minpoly.natDegree = 2 := by
  unfold α_32_minpoly
  compute_degree!

lemma α_32_minpoly_degree_ne_zero : α_32_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_32_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_32_minpoly_natDegree]
  decide

/-- α is some root of the degree-2 minimal polynomial in ℂ. -/
noncomputable def α_32 : ℂ :=
  (IsAlgClosed.exists_root α_32_minpoly α_32_minpoly_degree_ne_zero).choose

lemma α_32_isRoot : Polynomial.IsRoot α_32_minpoly α_32 :=
  (IsAlgClosed.exists_root α_32_minpoly α_32_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_32_is_root :
    α_32 ^ 2 +
      (-2235350016) +
      (-39960) * α_32 = 0 := by
  have h := α_32_isRoot
  unfold Polynomial.IsRoot α_32_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


/-! ## Piece 0: coefficient of α^0 -/


def f_32_part_0_polyData : List (ℕ × ℕ × ℚ) :=
  [(2, 4, ((-(49 / 124416)))), (5, 2, (13 / 62208)), (8, 0, (23 / 124416))]

noncomputable def f_32_part_0 : ModularForm 𝒮ℒ 32 :=
  (((-(49 / 124416))) : ℂ) • mkMonomForm 2 4 32 (by decide) +
  ((13 / 62208) : ℂ) • mkMonomForm 5 2 32 (by decide) +
  ((23 / 124416) : ℂ) • mkMonomForm 8 0 32 (by decide)

lemma f_32_part_0_qExpansion_eq_evalEisPS :
    qExpansion 1 (f_32_part_0 : ℍ → ℂ) = evalEisPS f_32_part_0_polyData := by
  unfold f_32_part_0
  rw [ModularForm.coe_add,
    ModularForm.qExpansion_add one_pos one_mem_strictPeriods_SL,
    ModularForm.coe_add,
    ModularForm.qExpansion_add one_pos one_mem_strictPeriods_SL,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
    qExpansion_mkMonomForm,
    qExpansion_mkMonomForm,
    qExpansion_mkMonomForm]
  unfold evalEisPS f_32_part_0_polyData monomialEisPS
  simp only [List.foldr_cons, List.foldr_nil, add_zero]
  push_cast
  module

theorem f_32_part_0_qExpansion_coeff (N n : ℕ) (hn : n < N) :
    (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (f_32_part_0 : ℍ → ℂ))
      = ((evalEisList f_32_part_0_polyData N).getD n 0 : ℚ) :=
  qexp_coeff_via_E4E6 _ _ f_32_part_0_qExpansion_eq_evalEisPS N n hn

