/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-32 modular form `f` whose first 3
q-coefficients match the LMFDB-published values for `1.32.a.{a..}` is equal to our
explicit construction `lmfdb_1_32_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_32_a_orbit (f : ModularForm 𝒮ℒ 32)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_32) :
    f = lmfdb_1_32_a_orbit := by
  apply ModularForm.eq_of_sturm_bound
  intro i hi
  have : i ≤ 2 := by omega
  interval_cases i
  · rw [h_0, lmfdb_1_32_a_orbit_qExpansion_coeff_0]
  · rw [h_1, lmfdb_1_32_a_orbit_qExpansion_coeff_1]
  · rw [h_2, lmfdb_1_32_a_orbit_qExpansion_coeff_2]


