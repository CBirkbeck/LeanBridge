/-- Minimal polynomial of α (degree 4) as `Polynomial ℂ`. -/
noncomputable def α_56_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 4 +
    Polynomial.C (-255678332805518077225389998997504) +
    Polynomial.C 11031882363768735132549120 * Polynomial.X +
    Polynomial.C (-69659795501724672) * Polynomial.X ^ 2 +
    Polynomial.C (-208622520) * Polynomial.X ^ 3

lemma α_56_minpoly_natDegree : α_56_minpoly.natDegree = 4 := by
  unfold α_56_minpoly
  compute_degree!

lemma α_56_minpoly_degree_ne_zero : α_56_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_56_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_56_minpoly_natDegree]
  decide

/-- α is some root of the degree-4 minimal polynomial in ℂ. -/
noncomputable def α_56 : ℂ :=
  (IsAlgClosed.exists_root α_56_minpoly α_56_minpoly_degree_ne_zero).choose

lemma α_56_isRoot : Polynomial.IsRoot α_56_minpoly α_56 :=
  (IsAlgClosed.exists_root α_56_minpoly α_56_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_56_is_root :
    α_56 ^ 4 +
      (-255678332805518077225389998997504) +
      11031882363768735132549120 * α_56 +
      (-69659795501724672) * α_56 ^ 2 +
      (-208622520) * α_56 ^ 3 = 0 := by
  have h := α_56_isRoot
  unfold Polynomial.IsRoot α_56_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


