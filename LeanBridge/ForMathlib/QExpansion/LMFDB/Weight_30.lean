/-- Minimal polynomial of α (degree 2) as `Polynomial ℂ`. -/
noncomputable def α_30_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 2 +
    Polynomial.C (-454569984) +
    Polynomial.C (-8640) * Polynomial.X

lemma α_30_minpoly_natDegree : α_30_minpoly.natDegree = 2 := by
  unfold α_30_minpoly
  compute_degree!

lemma α_30_minpoly_degree_ne_zero : α_30_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_30_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_30_minpoly_natDegree]
  decide

/-- α is some root of the degree-2 minimal polynomial in ℂ. -/
noncomputable def α_30 : ℂ :=
  (IsAlgClosed.exists_root α_30_minpoly α_30_minpoly_degree_ne_zero).choose

lemma α_30_isRoot : Polynomial.IsRoot α_30_minpoly α_30 :=
  (IsAlgClosed.exists_root α_30_minpoly α_30_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_30_is_root :
    α_30 ^ 2 +
      (-454569984) +
      (-8640) * α_30 = 0 := by
  have h := α_30_isRoot
  unfold Polynomial.IsRoot α_30_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


/-! ## Piece 0: coefficient of α^0 -/


def f_30_part_0_polyData : List (ℕ × ℕ × ℚ) :=
  [(0, 5, ((-(1 / 15552)))), (3, 3, ((-(7 / 15552)))), (6, 1, (1 / 1944))]

noncomputable def f_30_part_0 : ModularForm 𝒮ℒ 30 :=
  (((-(1 / 15552))) : ℂ) • mkMonomForm 0 5 30 (by decide) +
  (((-(7 / 15552))) : ℂ) • mkMonomForm 3 3 30 (by decide) +
  ((1 / 1944) : ℂ) • mkMonomForm 6 1 30 (by decide)

lemma f_30_part_0_qExpansion_eq_evalEisPS :
    qExpansion 1 (f_30_part_0 : ℍ → ℂ) = evalEisPS f_30_part_0_polyData := by
  unfold f_30_part_0
  rw [ModularForm.coe_add,
    ModularForm.qExpansion_add one_pos one_mem_strictPeriods_SL,
    ModularForm.coe_add,
    ModularForm.qExpansion_add one_pos one_mem_strictPeriods_SL,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
