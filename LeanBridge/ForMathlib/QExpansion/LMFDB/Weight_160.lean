/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-160 modular form `f` whose first 14
q-coefficients match the LMFDB-published values for `1.160.a.{a..}` is equal to our
explicit construction `lmfdb_1_160_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_160_a_orbit (f : ModularForm 𝒮ℒ 160)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_160)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_160 + ((-( / ))) * α_160 ^ 2 + ( / ) * α_160 ^ 3 + ( / ) * α_160 ^ 4 + ( / ) * α_160 ^ 5 + ((-( / ))) * α_160 ^ 6 + ((-( / ))) * α_160 ^ 7 + ( / ) * α_160 ^ 8 + ( / ) * α_160 ^ 9 + ((-( / ))) * α_160 ^ 10 + ((-( / ))) * α_160 ^ 11 + ( / ) * α_160 ^ 12)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-730750818665451459101842416358141509827966271488) + 1 * α_160 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_160 + ( / ) * α_160 ^ 2 + ( / ) * α_160 ^ 3 + ((-( / ))) * α_160 ^ 4 + ((-( / ))) * α_160 ^ 5 + ( / ) * α_160 ^ 6 + ( / ) * α_160 ^ 7 + ((-( / ))) * α_160 ^ 8 + ((-( / ))) * α_160 ^ 9 + ( / ) * α_160 ^ 10 + ( / ) * α_160 ^ 11 + ((-( / ))) * α_160 ^ 12)
    (h_6 : (PowerSeries.coeff (R := ℂ) 6) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_160 + ((-( / ))) * α_160 ^ 2 + ((-( / ))) * α_160 ^ 3 + ( / ) * α_160 ^ 4 + ( / ) * α_160 ^ 5 + ((-( / ))) * α_160 ^ 6 + ((-( / ))) * α_160 ^ 7 + ( / ) * α_160 ^ 8 + ( / ) * α_160 ^ 9 + ((-( / ))) * α_160 ^ 10 + ((-( / ))) * α_160 ^ 11 + ( / ) * α_160 ^ 12)
    (h_7 : (PowerSeries.coeff (R := ℂ) 7) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ((-( / ))) * α_160 + ( / ) * α_160 ^ 2 + ( / ) * α_160 ^ 3 + ((-( / ))) * α_160 ^ 4 + ((-( / ))) * α_160 ^ 5 + ( / ) * α_160 ^ 6 + ( / ) * α_160 ^ 7 + ((-( / ))) * α_160 ^ 8 + ((-( / ))) * α_160 ^ 9 + ( / ) * α_160 ^ 10 + ( / ) * α_160 ^ 11 + ((-( / ))) * α_160 ^ 12)
