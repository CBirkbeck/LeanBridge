/-!
# LMFDB level-1 modular form orbit `1.26.a.{a..}` (Hecke field degree 1)

The Hecke field `K = ℚ(α)` is degree 1 over ℚ. The LMFDB lists q-coefficients as
elements of `K`, which we decompose as `c_0 + c_1 · α + … + c_{0} · α^0`.
The combined form is `f = f_0 + α · f_1 + … + α^0 · f_{0}`, with each
`f_j` a level-1 weight-26 form with rational coefficients in `(E₄, E₆)`.

The Sturm bound for weight 26 is `⌊26/12⌋ + 1 = 3`. After certifying agreement
on the first 3 q-coefficients, `ModularForm.eq_of_sturm_bound` lets us conclude that any
form with the same coefficients equals our explicit `lmfdb_1_26_a_orbit`.

Generated by `scripts/lmfdb_qexp_to_e4e6_v3.sage`.
-/

namespace LeanBridge.QExpansion.LMFDB.W26

open LeanBridge.QExpansion ModularForm EisensteinSeries PowerSeries UpperHalfPlane
open scoped MatrixGroups


/-- Minimal polynomial of α (degree 1) as `Polynomial ℂ`. -/
noncomputable def α_26_minpoly : Polynomial ℂ :=
  Polynomial.X +
    Polynomial.C (-1)

lemma α_26_minpoly_natDegree : α_26_minpoly.natDegree = 1 := by
  unfold α_26_minpoly
  compute_degree!

lemma α_26_minpoly_degree_ne_zero : α_26_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_26_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_26_minpoly_natDegree]
  decide

/-- α is some root of the degree-1 minimal polynomial in ℂ. -/
noncomputable def α_26 : ℂ :=
  (IsAlgClosed.exists_root α_26_minpoly α_26_minpoly_degree_ne_zero).choose

lemma α_26_isRoot : Polynomial.IsRoot α_26_minpoly α_26 :=
  (IsAlgClosed.exists_root α_26_minpoly α_26_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_26_is_root :
    α_26 +
      (-1) = 0 := by
  have h := α_26_isRoot
  unfold Polynomial.IsRoot α_26_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


/-! ## Piece 0: coefficient of α^0 -/


def f_26_part_0_polyData : List (ℕ × ℕ × ℚ) :=
  [(2, 3, ((-(1 / 1728)))), (5, 1, (1 / 1728))]

noncomputable def f_26_part_0 : ModularForm 𝒮ℒ 26 :=
  (((-(1 / 1728))) : ℂ) • mkMonomForm 2 3 26 (by decide) +
  ((1 / 1728) : ℂ) • mkMonomForm 5 1 26 (by decide)

lemma f_26_part_0_qExpansion_eq_evalEisPS :
    qExpansion 1 (f_26_part_0 : ℍ → ℂ) = evalEisPS f_26_part_0_polyData := by
  unfold f_26_part_0
  rw [ModularForm.coe_add,
    ModularForm.qExpansion_add one_pos one_mem_strictPeriods_SL,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
    qExpansion_mkMonomForm,
    qExpansion_mkMonomForm]
  unfold evalEisPS f_26_part_0_polyData monomialEisPS
  simp only [List.foldr_cons, List.foldr_nil, add_zero]
  push_cast
  module

theorem f_26_part_0_qExpansion_coeff (N n : ℕ) (hn : n < N) :
    (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (f_26_part_0 : ℍ → ℂ))
      = ((evalEisList f_26_part_0_polyData N).getD n 0 : ℚ) :=
  qexp_coeff_via_E4E6 _ _ f_26_part_0_qExpansion_eq_evalEisPS N n hn

/-- Precomputed first 10 q-coefficients of `f_26_part_0` (rational). -/
def f_26_part_0_qExpList : List ℚ :=
  [0, 1, (-48), (-195804), (-33552128), (-741989850), 9398592, 39080597192, 3221114880, (-808949403027)]

/-- One-shot bridge: the symbolic `evalEisList` equals the precomputed list (verified by
`decide +kernel` once instead of N times). -/
lemma f_26_part_0_evalEisList_eq :
    evalEisList f_26_part_0_polyData 10 = f_26_part_0_qExpList := by
  decide +kernel


/-! ## Combined LMFDB form -/


noncomputable def lmfdb_1_26_a_orbit : ModularForm 𝒮ℒ 26 :=
  f_26_part_0

lemma lmfdb_1_26_a_orbit_coeff_decomp (n : ℕ) :
    (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (lmfdb_1_26_a_orbit : ℍ → ℂ))
      = (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (f_26_part_0 : ℍ → ℂ)) := by
  rfl


