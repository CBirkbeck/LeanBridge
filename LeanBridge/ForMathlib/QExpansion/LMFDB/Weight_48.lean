/-- Minimal polynomial of α (degree 4) as `Polynomial ℂ`. -/
noncomputable def α_48_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 4 +
    Polynomial.C 3297913828840214320807673856 +
    Polynomial.C 1426830562183253852160 * Polynomial.X +
    Polynomial.C (-467142374034432) * Polynomial.X ^ 2 +
    Polynomial.C (-5785560) * Polynomial.X ^ 3

lemma α_48_minpoly_natDegree : α_48_minpoly.natDegree = 4 := by
  unfold α_48_minpoly
  compute_degree!

lemma α_48_minpoly_degree_ne_zero : α_48_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_48_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_48_minpoly_natDegree]
  decide

/-- α is some root of the degree-4 minimal polynomial in ℂ. -/
noncomputable def α_48 : ℂ :=
  (IsAlgClosed.exists_root α_48_minpoly α_48_minpoly_degree_ne_zero).choose

lemma α_48_isRoot : Polynomial.IsRoot α_48_minpoly α_48 :=
  (IsAlgClosed.exists_root α_48_minpoly α_48_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_48_is_root :
    α_48 ^ 4 +
      3297913828840214320807673856 +
      1426830562183253852160 * α_48 +
      (-467142374034432) * α_48 ^ 2 +
      (-5785560) * α_48 ^ 3 = 0 := by
  have h := α_48_isRoot
  unfold Polynomial.IsRoot α_48_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


