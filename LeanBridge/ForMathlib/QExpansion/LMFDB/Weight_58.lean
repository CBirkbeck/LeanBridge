/-- Minimal polynomial of α (degree 4) as `Polynomial ℂ`. -/
noncomputable def α_58_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 4 +
    Polynomial.C 18678231666950985607375948785647616 +
    Polynomial.C (-42515907658957794091991040) * Polynomial.X +
    Polynomial.C (-411086477602603008) * Polynomial.X ^ 2 +
    Polynomial.C 217744560 * Polynomial.X ^ 3

lemma α_58_minpoly_natDegree : α_58_minpoly.natDegree = 4 := by
  unfold α_58_minpoly
  compute_degree!

lemma α_58_minpoly_degree_ne_zero : α_58_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_58_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_58_minpoly_natDegree]
  decide

/-- α is some root of the degree-4 minimal polynomial in ℂ. -/
noncomputable def α_58 : ℂ :=
  (IsAlgClosed.exists_root α_58_minpoly α_58_minpoly_degree_ne_zero).choose

lemma α_58_isRoot : Polynomial.IsRoot α_58_minpoly α_58 :=
  (IsAlgClosed.exists_root α_58_minpoly α_58_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_58_is_root :
    α_58 ^ 4 +
      18678231666950985607375948785647616 +
      (-42515907658957794091991040) * α_58 +
      (-411086477602603008) * α_58 ^ 2 +
      217744560 * α_58 ^ 3 = 0 := by
  have h := α_58_isRoot
  unfold Polynomial.IsRoot α_58_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


