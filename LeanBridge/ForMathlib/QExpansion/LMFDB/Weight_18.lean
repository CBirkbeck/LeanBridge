/-!
# LMFDB level-1 modular form orbit `1.18.a.{a..}` (Hecke field degree 1)

The Hecke field `K = ℚ(α)` is degree 1 over ℚ. The LMFDB lists q-coefficients as
elements of `K`, which we decompose as `c_0 + c_1 · α + … + c_{0} · α^0`.
The combined form is `f = f_0 + α · f_1 + … + α^0 · f_{0}`, with each
`f_j` a level-1 weight-18 form with rational coefficients in `(E₄, E₆)`.

The Sturm bound for weight 18 is `⌊18/12⌋ + 1 = 2`. After certifying agreement
on the first 2 q-coefficients, `ModularForm.eq_of_sturm_bound` lets us conclude that any
form with the same coefficients equals our explicit `lmfdb_1_18_a_orbit`.

Generated by `scripts/lmfdb_qexp_to_e4e6_v3.sage`.
-/

namespace LeanBridge.QExpansion.LMFDB.W18

open LeanBridge.QExpansion ModularForm EisensteinSeries PowerSeries UpperHalfPlane
open scoped MatrixGroups


/-- Minimal polynomial of α (degree 1) as `Polynomial ℂ`. -/
noncomputable def α_18_minpoly : Polynomial ℂ :=
  Polynomial.X +
    Polynomial.C (-1)

lemma α_18_minpoly_natDegree : α_18_minpoly.natDegree = 1 := by
  unfold α_18_minpoly
  compute_degree!

lemma α_18_minpoly_degree_ne_zero : α_18_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_18_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_18_minpoly_natDegree]
  decide

/-- α is some root of the degree-1 minimal polynomial in ℂ. -/
noncomputable def α_18 : ℂ :=
  (IsAlgClosed.exists_root α_18_minpoly α_18_minpoly_degree_ne_zero).choose

lemma α_18_isRoot : Polynomial.IsRoot α_18_minpoly α_18 :=
  (IsAlgClosed.exists_root α_18_minpoly α_18_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_18_is_root :
    α_18 +
      (-1) = 0 := by
  have h := α_18_isRoot
  unfold Polynomial.IsRoot α_18_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


/-! ## Piece 0: coefficient of α^0 -/


def f_18_part_0_polyData : List (ℕ × ℕ × ℚ) :=
  [(0, 3, ((-(1 / 1728)))), (3, 1, (1 / 1728))]

noncomputable def f_18_part_0 : ModularForm 𝒮ℒ 18 :=
  (((-(1 / 1728))) : ℂ) • mkMonomForm 0 3 18 (by decide) +
  ((1 / 1728) : ℂ) • mkMonomForm 3 1 18 (by decide)

lemma f_18_part_0_qExpansion_eq_evalEisPS :
    qExpansion 1 (f_18_part_0 : ℍ → ℂ) = evalEisPS f_18_part_0_polyData := by
  unfold f_18_part_0
  rw [ModularForm.coe_add,
    ModularForm.qExpansion_add one_pos one_mem_strictPeriods_SL,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
    qExpansion_mkMonomForm,
    qExpansion_mkMonomForm]
  unfold evalEisPS f_18_part_0_polyData monomialEisPS
  simp only [List.foldr_cons, List.foldr_nil, add_zero]
  push_cast
  module

theorem f_18_part_0_qExpansion_coeff (N n : ℕ) (hn : n < N) :
    (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (f_18_part_0 : ℍ → ℂ))
      = ((evalEisList f_18_part_0_polyData N).getD n 0 : ℚ) :=
  qexp_coeff_via_E4E6 _ _ f_18_part_0_qExpansion_eq_evalEisPS N n hn

/-- Precomputed first 10 q-coefficients of `f_18_part_0` (rational). -/
def f_18_part_0_qExpList : List ℚ :=
  [0, 1, (-528), (-4284), 147712, (-1025850), 2261952, 3225992, (-8785920), (-110787507)]

/-- One-shot bridge: the symbolic `evalEisList` equals the precomputed list (verified by
`decide +kernel` once instead of N times). -/
lemma f_18_part_0_evalEisList_eq :
    evalEisList f_18_part_0_polyData 10 = f_18_part_0_qExpList := by
  decide +kernel


/-! ## Combined LMFDB form -/


noncomputable def lmfdb_1_18_a_orbit : ModularForm 𝒮ℒ 18 :=
  f_18_part_0

lemma lmfdb_1_18_a_orbit_coeff_decomp (n : ℕ) :
    (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (lmfdb_1_18_a_orbit : ℍ → ℂ))
      = (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (f_18_part_0 : ℍ → ℂ)) := by
  rfl


