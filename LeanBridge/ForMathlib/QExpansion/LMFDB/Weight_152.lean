/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-152 modular form `f` whose first 13
q-coefficients match the LMFDB-published values for `1.152.a.{a..}` is equal to our
explicit construction `lmfdb_1_152_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_152_a_orbit (f : ModularForm 𝒮ℒ 152)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_152)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_152 + ((-( / ))) * α_152 ^ 2 + ( / ) * α_152 ^ 3 + ( / ) * α_152 ^ 4 + ((-( / ))) * α_152 ^ 5 + ((-( / ))) * α_152 ^ 6 + ( / ) * α_152 ^ 7 + ( / ) * α_152 ^ 8 + ((-( / ))) * α_152 ^ 9 + ((-( / ))) * α_152 ^ 10 + ( / ) * α_152 ^ 11)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-2854495385411919762116571938898990272765493248) + 1 * α_152 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_152 + ( / ) * α_152 ^ 2 + ( / ) * α_152 ^ 3 + ((-( / ))) * α_152 ^ 4 + ((-( / ))) * α_152 ^ 5 + ( / ) * α_152 ^ 6 + ( / ) * α_152 ^ 7 + ((-( / ))) * α_152 ^ 8 + ((-( / ))) * α_152 ^ 9 + ( / ) * α_152 ^ 10 + ( / ) * α_152 ^ 11)
    (h_6 : (PowerSeries.coeff (R := ℂ) 6) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_152 + ( / ) * α_152 ^ 2 + ( / ) * α_152 ^ 3 + ((-( / ))) * α_152 ^ 4 + ((-( / ))) * α_152 ^ 5 + ( / ) * α_152 ^ 6 + ( / ) * α_152 ^ 7 + ((-( / ))) * α_152 ^ 8 + ((-( / ))) * α_152 ^ 9 + ( / ) * α_152 ^ 10 + ( / ) * α_152 ^ 11)
    (h_7 : (PowerSeries.coeff (R := ℂ) 7) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_152 + ((-( / ))) * α_152 ^ 2 + ( / ) * α_152 ^ 3 + ( / ) * α_152 ^ 4 + ((-( / ))) * α_152 ^ 5 + ((-( / ))) * α_152 ^ 6 + ( / ) * α_152 ^ 7 + ( / ) * α_152 ^ 8 + ((-( / ))) * α_152 ^ 9 + ((-( / ))) * α_152 ^ 10 + ( / ) * α_152 ^ 11)
    (h_8 : (PowerSeries.coeff (R := ℂ) 8) (qExpansion 1 (f : ℍ → ℂ)) = (-5708990770823839524233143877797980545530986496) * α_152 + 1 * α_152 ^ 3)
    (h_9 : (PowerSeries.coeff (R := ℂ) 9) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ( / ) * α_152 + ((-( / ))) * α_152 ^ 2 + ((-( / ))) * α_152 ^ 3 + ( / ) * α_152 ^ 4 + ( / ) * α_152 ^ 5 + ((-( / ))) * α_152 ^ 6 + ((-( / ))) * α_152 ^ 7 + ( / ) * α_152 ^ 8 + ( / ) * α_152 ^ 9 + ((-( / ))) * α_152 ^ 10 + ((-( / ))) * α_152 ^ 11)
    (h_10 : (PowerSeries.coeff (R := ℂ) 10) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_152 + ( / ) * α_152 ^ 2 + ( / ) * α_152 ^ 3 + ((-( / ))) * α_152 ^ 4 + ((-( / ))) * α_152 ^ 5 + ( / ) * α_152 ^ 6 + ( / ) * α_152 ^ 7 + ((-( / ))) * α_152 ^ 8 + ((-( / ))) * α_152 ^ 9 + ( / ) * α_152 ^ 10 + ( / ) * α_152 ^ 11)
    (h_11 : (PowerSeries.coeff (R := ℂ) 11) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ( / ) * α_152 + ((-( / ))) * α_152 ^ 2 + ((-( / ))) * α_152 ^ 3 + ( / ) * α_152 ^ 4 + ( / ) * α_152 ^ 5 + ((-( / ))) * α_152 ^ 6 + ((-( / ))) * α_152 ^ 7 + ((-( / ))) * α_152 ^ 8 + ( / ) * α_152 ^ 9 + ( / ) * α_152 ^ 10 + ((-( / ))) * α_152 ^ 11)
