/-- Minimal polynomial of α (degree 3) as `Polynomial ℂ`. -/
noncomputable def α_44_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 3 +
    Polynomial.C (-19976984434430705664) +
    Polynomial.C (-15663522502656) * Polynomial.X +
    Polynomial.C 2209944 * Polynomial.X ^ 2

lemma α_44_minpoly_natDegree : α_44_minpoly.natDegree = 3 := by
  unfold α_44_minpoly
  compute_degree!

lemma α_44_minpoly_degree_ne_zero : α_44_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_44_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_44_minpoly_natDegree]
  decide

/-- α is some root of the degree-3 minimal polynomial in ℂ. -/
noncomputable def α_44 : ℂ :=
  (IsAlgClosed.exists_root α_44_minpoly α_44_minpoly_degree_ne_zero).choose

lemma α_44_isRoot : Polynomial.IsRoot α_44_minpoly α_44 :=
  (IsAlgClosed.exists_root α_44_minpoly α_44_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_44_is_root :
    α_44 ^ 3 +
      (-19976984434430705664) +
      (-15663522502656) * α_44 +
      2209944 * α_44 ^ 2 = 0 := by
  have h := α_44_isRoot
  unfold Polynomial.IsRoot α_44_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


