/-- Minimal polynomial of α (degree 5) as `Polynomial ℂ`. -/
noncomputable def α_64_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 5 +
    Polynomial.C 59899702063757157544982491709928053576589901824 +
    Polynomial.C 93356730870958242939964792647614201856 * Polynomial.X +
    Polynomial.C 7816999697067374824780726272 * Polynomial.X ^ 2 +
    Polynomial.C (-26316207229657439232) * Polynomial.X ^ 3 +
    Polynomial.C (-507315096) * Polynomial.X ^ 4

lemma α_64_minpoly_natDegree : α_64_minpoly.natDegree = 5 := by
  unfold α_64_minpoly
  compute_degree!

lemma α_64_minpoly_degree_ne_zero : α_64_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_64_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_64_minpoly_natDegree]
  decide

/-- α is some root of the degree-5 minimal polynomial in ℂ. -/
noncomputable def α_64 : ℂ :=
  (IsAlgClosed.exists_root α_64_minpoly α_64_minpoly_degree_ne_zero).choose

lemma α_64_isRoot : Polynomial.IsRoot α_64_minpoly α_64 :=
  (IsAlgClosed.exists_root α_64_minpoly α_64_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_64_is_root :
    α_64 ^ 5 +
      59899702063757157544982491709928053576589901824 +
      93356730870958242939964792647614201856 * α_64 +
      7816999697067374824780726272 * α_64 ^ 2 +
      (-26316207229657439232) * α_64 ^ 3 +
      (-507315096) * α_64 ^ 4 = 0 := by
  have h := α_64_isRoot
  unfold Polynomial.IsRoot α_64_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


