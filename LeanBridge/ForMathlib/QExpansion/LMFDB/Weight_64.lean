/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-64 modular form `f` whose first 6
q-coefficients match the LMFDB-published values for `1.64.a.{a..}` is equal to our
explicit construction `lmfdb_1_64_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_64_a_orbit (f : ModularForm 𝒮ℒ 64)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_64)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ((-(404496705296989095162023821572 / 46412549065757))) + ((-(67521601525164741914955 / 11881612560833792))) * α_64 + (1086535311071367229 / 292002510295051272192) * α_64 ^ 2 + (90011647673 / 336386891859899065565184) * α_64 ^ 3 + ((-(3643 / 24219856213912732720693248))) * α_64 ^ 4)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-9223372036854775808) + 1 * α_64 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = (20782946576056375227107038231991365038 / 232062745328785) + (135651488643513059526938376325 / 2970403140208448) * α_64 + ((-(4836572597772089598089493 / 121667712622938030080))) * α_64 ^ 2 + ((-(6347637419650325 / 3114693443147213570048))) * α_64 ^ 3 + (202800051 / 124587737725888542801920) * α_64 ^ 4) :
    f = lmfdb_1_64_a_orbit := by
  apply ModularForm.eq_of_sturm_bound
  intro i hi
  have : i ≤ 5 := by omega
  interval_cases i
  · rw [h_0, lmfdb_1_64_a_orbit_qExpansion_coeff_0]
  · rw [h_1, lmfdb_1_64_a_orbit_qExpansion_coeff_1]
  · rw [h_2, lmfdb_1_64_a_orbit_qExpansion_coeff_2]
  · rw [h_3, lmfdb_1_64_a_orbit_qExpansion_coeff_3]
  · rw [h_4, lmfdb_1_64_a_orbit_qExpansion_coeff_4]
  · rw [h_5, lmfdb_1_64_a_orbit_qExpansion_coeff_5]


