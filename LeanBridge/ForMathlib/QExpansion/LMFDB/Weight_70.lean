/-- Minimal polynomial of α (degree 5) as `Polynomial ℂ`. -/
noncomputable def α_70_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 5 +
    Polynomial.C 4169744246282611427836654706819235757668276180615168 +
    Polynomial.C 613518461067953168654246762332094963122176 * Polynomial.X +
    Polynomial.C (-14539211744046993293953166475264) * Polynomial.X ^ 2 +
    Polynomial.C (-1942747456996431618048) * Polynomial.X ^ 3 +
    Polynomial.C 18005734368 * Polynomial.X ^ 4

lemma α_70_minpoly_natDegree : α_70_minpoly.natDegree = 5 := by
  unfold α_70_minpoly
  compute_degree!

lemma α_70_minpoly_degree_ne_zero : α_70_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_70_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_70_minpoly_natDegree]
  decide

/-- α is some root of the degree-5 minimal polynomial in ℂ. -/
noncomputable def α_70 : ℂ :=
  (IsAlgClosed.exists_root α_70_minpoly α_70_minpoly_degree_ne_zero).choose

lemma α_70_isRoot : Polynomial.IsRoot α_70_minpoly α_70 :=
  (IsAlgClosed.exists_root α_70_minpoly α_70_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_70_is_root :
    α_70 ^ 5 +
      4169744246282611427836654706819235757668276180615168 +
      613518461067953168654246762332094963122176 * α_70 +
      (-14539211744046993293953166475264) * α_70 ^ 2 +
      (-1942747456996431618048) * α_70 ^ 3 +
      18005734368 * α_70 ^ 4 = 0 := by
  have h := α_70_isRoot
  unfold Polynomial.IsRoot α_70_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


