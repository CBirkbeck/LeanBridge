    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-11150372599265311570767859136324180752990208) + 1 * α_144 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_144 + ((-( / ))) * α_144 ^ 2 + ( / ) * α_144 ^ 3 + ( / ) * α_144 ^ 4 + ((-( / ))) * α_144 ^ 5 + ((-( / ))) * α_144 ^ 6 + ( / ) * α_144 ^ 7 + ( / ) * α_144 ^ 8 + ((-( / ))) * α_144 ^ 9 + ((-( / ))) * α_144 ^ 10 + ( / ) * α_144 ^ 11)
