/-- Minimal polynomial of α (degree 3) as `Polynomial ℂ`. -/
noncomputable def α_50_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 3 +
    Polynomial.C (-13634883228742736412672) +
    Polynomial.C (-566746931810304) * Polynomial.X +
    Polynomial.C 24225168 * Polynomial.X ^ 2

lemma α_50_minpoly_natDegree : α_50_minpoly.natDegree = 3 := by
  unfold α_50_minpoly
  compute_degree!

lemma α_50_minpoly_degree_ne_zero : α_50_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_50_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_50_minpoly_natDegree]
  decide

/-- α is some root of the degree-3 minimal polynomial in ℂ. -/
noncomputable def α_50 : ℂ :=
  (IsAlgClosed.exists_root α_50_minpoly α_50_minpoly_degree_ne_zero).choose

lemma α_50_isRoot : Polynomial.IsRoot α_50_minpoly α_50 :=
  (IsAlgClosed.exists_root α_50_minpoly α_50_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_50_is_root :
    α_50 ^ 3 +
      (-13634883228742736412672) +
      (-566746931810304) * α_50 +
      24225168 * α_50 ^ 2 = 0 := by
  have h := α_50_isRoot
  unfold Polynomial.IsRoot α_50_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


