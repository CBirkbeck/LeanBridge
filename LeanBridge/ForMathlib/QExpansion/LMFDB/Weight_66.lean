/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-66 modular form `f` whose first 6
q-coefficients match the LMFDB-published values for `1.66.a.{a..}` is equal to our
explicit construction `lmfdb_1_66_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_66_a_orbit (f : ModularForm 𝒮ℒ 66)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_66)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ((-(771042237858654912966095212 / 149048552709))) + ((-(875524182419449759705 / 158682294084096))) * α_66 + ((-(872040691401690733 / 1474115350457260965888))) * α_66 ^ 2 + (3895454719 / 41930392190784311918592) * α_66 ^ 3 + (77 / 7763112611322352606642176) * α_66 ^ 4)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-36893488147419103232) + 1 * α_66 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = (212707656396349487157041644846014 / 1840105589) + (2657732487164605484064493375 / 30854890516352) * α_66 + (1630676453530757419341 / 505526526219911168) * α_66 ^ 2 + ((-(24495376912625 / 18487827244613894144))) * α_66 ^ 3 + ((-(178467 / 2070636651396756144128))) * α_66 ^ 4) :
    f = lmfdb_1_66_a_orbit := by
  apply ModularForm.eq_of_sturm_bound
  intro i hi
  have : i ≤ 5 := by omega
