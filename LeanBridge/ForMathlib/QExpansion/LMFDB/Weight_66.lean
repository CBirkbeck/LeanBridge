/-- Minimal polynomial of α (degree 5) as `Polynomial ℂ`. -/
noncomputable def α_66_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 5 +
    Polynomial.C 6737365607750178848535412403321340119893376237568 +
    Polynomial.C 4888759358323485530147825225712235708416 * Polynomial.X +
    Polynomial.C (-339986038308627409973683421184) * Polynomial.X ^ 2 +
    Polynomial.C (-142850166119005483008) * Polynomial.X ^ 3 +
    Polynomial.C 3959709648 * Polynomial.X ^ 4

lemma α_66_minpoly_natDegree : α_66_minpoly.natDegree = 5 := by
  unfold α_66_minpoly
  compute_degree!

lemma α_66_minpoly_degree_ne_zero : α_66_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_66_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_66_minpoly_natDegree]
  decide

/-- α is some root of the degree-5 minimal polynomial in ℂ. -/
noncomputable def α_66 : ℂ :=
  (IsAlgClosed.exists_root α_66_minpoly α_66_minpoly_degree_ne_zero).choose

lemma α_66_isRoot : Polynomial.IsRoot α_66_minpoly α_66 :=
  (IsAlgClosed.exists_root α_66_minpoly α_66_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_66_is_root :
    α_66 ^ 5 +
      6737365607750178848535412403321340119893376237568 +
      4888759358323485530147825225712235708416 * α_66 +
      (-339986038308627409973683421184) * α_66 ^ 2 +
      (-142850166119005483008) * α_66 ^ 3 +
      3959709648 * α_66 ^ 4 = 0 := by
  have h := α_66_isRoot
  unfold Polynomial.IsRoot α_66_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


