/-- Minimal polynomial of α (degree 1) as `Polynomial ℂ`. -/
noncomputable def α_22_minpoly : Polynomial ℂ :=
  Polynomial.X +
    Polynomial.C (-1)

lemma α_22_minpoly_natDegree : α_22_minpoly.natDegree = 1 := by
  unfold α_22_minpoly
  compute_degree!

lemma α_22_minpoly_degree_ne_zero : α_22_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_22_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_22_minpoly_natDegree]
  decide

/-- α is some root of the degree-1 minimal polynomial in ℂ. -/
noncomputable def α_22 : ℂ :=
  (IsAlgClosed.exists_root α_22_minpoly α_22_minpoly_degree_ne_zero).choose

lemma α_22_isRoot : Polynomial.IsRoot α_22_minpoly α_22 :=
  (IsAlgClosed.exists_root α_22_minpoly α_22_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_22_is_root :
    α_22 +
      (-1) = 0 := by
  have h := α_22_isRoot
  unfold Polynomial.IsRoot α_22_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


/-! ## Piece 0: coefficient of α^0 -/


def f_22_part_0_polyData : List (ℕ × ℕ × ℚ) :=
  [(1, 3, ((-(1 / 1728)))), (4, 1, (1 / 1728))]

noncomputable def f_22_part_0 : ModularForm 𝒮ℒ 22 :=
  (((-(1 / 1728))) : ℂ) • mkMonomForm 1 3 22 (by decide) +
  ((1 / 1728) : ℂ) • mkMonomForm 4 1 22 (by decide)

lemma f_22_part_0_qExpansion_eq_evalEisPS :
    qExpansion 1 (f_22_part_0 : ℍ → ℂ) = evalEisPS f_22_part_0_polyData := by
  unfold f_22_part_0
  rw [ModularForm.coe_add,
    ModularForm.qExpansion_add one_pos one_mem_strictPeriods_SL,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL,
    qExpansion_mkMonomForm,
    qExpansion_mkMonomForm]
  unfold evalEisPS f_22_part_0_polyData monomialEisPS
  simp only [List.foldr_cons, List.foldr_nil, add_zero]
  push_cast
  module

theorem f_22_part_0_qExpansion_coeff (N n : ℕ) (hn : n < N) :
    (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (f_22_part_0 : ℍ → ℂ))
      = ((evalEisList f_22_part_0_polyData N).getD n 0 : ℚ) :=
  qexp_coeff_via_E4E6 _ _ f_22_part_0_qExpansion_eq_evalEisPS N n hn

/-- Precomputed first 10 q-coefficients of `f_22_part_0` (rational). -/
def f_22_part_0_qExpList : List ℚ :=
  [0, 1, (-288), (-128844), (-2014208), 21640950, 37107072, (-768078808), 1184071680, 6140423133]

/-- Bridge: the symbolic `evalEisList` (over ℚ) equals the precomputed list. The heavy kernel work
is the integer certificate `f_22_part_0_evalEisListZ_eq`; the steps here are cheap rational
list checks. -/
lemma f_22_part_0_evalEisList_eq :
    evalEisList f_22_part_0_polyData 10 = f_22_part_0_qExpList := by
  have h : f_22_part_0_polyData
      = f_22_part_0_polyDataZ.map
          (fun t => (t.1, t.2.1, (t.2.2 : ℚ) / f_22_part_0_scale)) := by
    decide +kernel
  rw [h, evalEisList_eq_intCast_div, f_22_part_0_evalEisListZ_eq]
  decide +kernel


/-! ## Combined LMFDB form -/


noncomputable def lmfdb_1_22_a_orbit : ModularForm 𝒮ℒ 22 :=
  f_22_part_0

lemma lmfdb_1_22_a_orbit_coeff_decomp (n : ℕ) :
    (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (lmfdb_1_22_a_orbit : ℍ → ℂ))
      = (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (f_22_part_0 : ℍ → ℂ)) := by
  rfl


