/-- Minimal polynomial of α (degree 2) as `Polynomial ℂ`. -/
noncomputable def α_38_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 2 +
    Polynomial.C (-137403408384) +
    Polynomial.C 194400 * Polynomial.X

lemma α_38_minpoly_natDegree : α_38_minpoly.natDegree = 2 := by
  unfold α_38_minpoly
  compute_degree!

lemma α_38_minpoly_degree_ne_zero : α_38_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_38_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_38_minpoly_natDegree]
  decide

/-- α is some root of the degree-2 minimal polynomial in ℂ. -/
noncomputable def α_38 : ℂ :=
  (IsAlgClosed.exists_root α_38_minpoly α_38_minpoly_degree_ne_zero).choose

lemma α_38_isRoot : Polynomial.IsRoot α_38_minpoly α_38 :=
  (IsAlgClosed.exists_root α_38_minpoly α_38_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_38_is_root :
    α_38 ^ 2 +
      (-137403408384) +
      194400 * α_38 = 0 := by
  have h := α_38_isRoot
  unfold Polynomial.IsRoot α_38_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


