/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-38 modular form `f` whose first 4
q-coefficients match the LMFDB-published values for `1.38.a.{a..}` is equal to our
explicit construction `lmfdb_1_38_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_38_a_orbit (f : ModularForm 𝒮ℒ 38)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_38)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = (-2700) + (-72) * α_38) :
    f = lmfdb_1_38_a_orbit := by
  apply ModularForm.eq_of_sturm_bound
  intro i hi
  have : i ≤ 3 := by omega
  interval_cases i
  · rw [h_0, lmfdb_1_38_a_orbit_qExpansion_coeff_0]
  · rw [h_1, lmfdb_1_38_a_orbit_qExpansion_coeff_1]
  · rw [h_2, lmfdb_1_38_a_orbit_qExpansion_coeff_2]
  · rw [h_3, lmfdb_1_38_a_orbit_qExpansion_coeff_3]


