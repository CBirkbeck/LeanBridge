/-- Minimal polynomial of α (degree 6) as `Polynomial ℂ`. -/
noncomputable def α_80_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 6 +
    Polynomial.C (-146067238099513054720421635022646234101475074700352906870756624885088256) +
    Polynomial.C 296032901024703008707204440039659404285760899529649023877120 * Polynomial.X +
    Polynomial.C 1718109851793900696170553960996854270563071295488 * Polynomial.X ^ 2 +
    Polynomial.C (-216009704480258385253119204198973440) * Polynomial.X ^ 3 +
    Polynomial.C (-2588128021566210544708608) * Polynomial.X ^ 4 +
    Polynomial.C 16086577320 * Polynomial.X ^ 5

lemma α_80_minpoly_natDegree : α_80_minpoly.natDegree = 6 := by
  unfold α_80_minpoly
  compute_degree!

lemma α_80_minpoly_degree_ne_zero : α_80_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_80_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_80_minpoly_natDegree]
  decide

/-- α is some root of the degree-6 minimal polynomial in ℂ. -/
noncomputable def α_80 : ℂ :=
  (IsAlgClosed.exists_root α_80_minpoly α_80_minpoly_degree_ne_zero).choose

lemma α_80_isRoot : Polynomial.IsRoot α_80_minpoly α_80 :=
  (IsAlgClosed.exists_root α_80_minpoly α_80_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_80_is_root :
    α_80 ^ 6 +
      (-146067238099513054720421635022646234101475074700352906870756624885088256) +
      296032901024703008707204440039659404285760899529649023877120 * α_80 +
      1718109851793900696170553960996854270563071295488 * α_80 ^ 2 +
      (-216009704480258385253119204198973440) * α_80 ^ 3 +
      (-2588128021566210544708608) * α_80 ^ 4 +
      16086577320 * α_80 ^ 5 = 0 := by
  have h := α_80_isRoot
  unfold Polynomial.IsRoot α_80_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


