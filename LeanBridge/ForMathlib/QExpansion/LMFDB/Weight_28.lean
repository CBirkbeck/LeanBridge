/-- Minimal polynomial of α (degree 2) as `Polynomial ℂ`. -/
noncomputable def α_28_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 2 +
    Polynomial.C (-195250176) +
    Polynomial.C 8280 * Polynomial.X

lemma α_28_minpoly_natDegree : α_28_minpoly.natDegree = 2 := by
  unfold α_28_minpoly
  compute_degree!

lemma α_28_minpoly_degree_ne_zero : α_28_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_28_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_28_minpoly_natDegree]
  decide

/-- α is some root of the degree-2 minimal polynomial in ℂ. -/
noncomputable def α_28 : ℂ :=
  (IsAlgClosed.exists_root α_28_minpoly α_28_minpoly_degree_ne_zero).choose

lemma α_28_isRoot : Polynomial.IsRoot α_28_minpoly α_28 :=
  (IsAlgClosed.exists_root α_28_minpoly α_28_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_28_is_root :
    α_28 ^ 2 +
      (-195250176) +
      8280 * α_28 = 0 := by
  have h := α_28_isRoot
  unfold Polynomial.IsRoot α_28_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


/-! ## Piece 0: coefficient of α^0 -/


def f_28_part_0_polyData : List (ℕ × ℕ × ℚ) :=
