/-! ## Combined LMFDB form -/


noncomputable def lmfdb_1_28_a_orbit : ModularForm 𝒮ℒ 28 :=
  f_28_part_0 +
  α_28 • f_28_part_1

lemma lmfdb_1_28_a_orbit_coeff_decomp (n : ℕ) :
    (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (lmfdb_1_28_a_orbit : ℍ → ℂ))
      = (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (f_28_part_0 : ℍ → ℂ))
        + α_28 * (PowerSeries.coeff (R := ℂ) n) (qExpansion 1 (f_28_part_1 : ℍ → ℂ)) := by
  unfold lmfdb_1_28_a_orbit
  rw [ModularForm.coe_add,
    ModularForm.qExpansion_add one_pos one_mem_strictPeriods_SL,
    ModularForm.IsGLPos.coe_smul,
    ModularForm.qExpansion_smul one_pos one_mem_strictPeriods_SL]
  simp [smul_eq_mul]


