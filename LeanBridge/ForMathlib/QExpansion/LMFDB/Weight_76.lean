/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-76 modular form `f` whose first 7
q-coefficients match the LMFDB-published values for `1.76.a.{a..}` is equal to our
explicit construction `lmfdb_1_76_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_76_a_orbit (f : ModularForm 𝒮ℒ 76)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_76)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ((-(18450263011050222811216082628589622372187365224020 / 12429824389064202543390630951701))) + (353542957334263552427665296054703077671 / 12728140174401743404432006094541824) * α_76 + (142884998869124172656535030102833335 / 1324828685334058923842771216948300611584) * α_76 ^ 2 + ((-(43013554399958313879316613051 / 415127119577315359432589304203448306836176896))) * α_76 ^ 3 + ((-(890996272783908278905 / 956452883506134588132685756884744898950551568384))) * α_76 ^ 4 + (83806050997 / 68864607612441690345553374495701632724439712923648) * α_76 ^ 5)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-37778931862957161709568) + 1 * α_76 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = (5647039310732844105996902118433536933241008138304948306446 / 62149121945321012716953154758505) + ((-(41915458788795661937328488912105000307653986474129 / 15910175218002179255540007618177280))) * α_76 + ((-(7183373474071069181236263171153950596290627 / 1042689243086990819691069939264866222080))) * α_76 ^ 2 + (179225451827254267941530854871453359 / 2135427569842157198727311235614446022819840) * α_76 ^ 3 + (37916204324767548055574733 / 546669457879592242874191676317298181841879040) * α_76 ^ 4 + ((-(2205022696597681 / 4373355663036737942993533410538385454735032320))) * α_76 ^ 5)
    (h_6 : (PowerSeries.coeff (R := ℂ) 6) (qExpansion 1 (f : ℍ → ℂ)) = (1394942294760884714818166427442986089484773643566664042676224 / 12429824389064202543390630951701) + ((-(22837218714396027738560775255504481226997791863380 / 12429824389064202543390630951701))) * α_76 + ((-(113092220218562551528224493010880431603119 / 9546105130801307553324004570906368))) * α_76 ^ 2 + (21419093773119562311451132864011235 / 175953809770929700822868052250946174976) * α_76 ^ 3 + (55682978270375423502213809 / 405397577712222030695887992386179987144704) * α_76 ^ 4 + ((-(1718744263574845 / 1716977976192940365300231497164997592612864))) * α_76 ^ 5) :
