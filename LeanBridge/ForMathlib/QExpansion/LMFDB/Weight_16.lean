/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-16 modular form `f` whose first 2
q-coefficients match the LMFDB-published values for `1.16.a.{a..}` is equal to our
explicit construction `lmfdb_1_16_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_16_a_orbit (f : ModularForm 𝒮ℒ 16)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1) :
    f = lmfdb_1_16_a_orbit := by
  apply ModularForm.eq_of_sturm_bound
  intro i hi
  have : i ≤ 1 := by omega
  interval_cases i
  · rw [h_0, lmfdb_1_16_a_orbit_qExpansion_coeff_0]
  · rw [h_1, lmfdb_1_16_a_orbit_qExpansion_coeff_1]


