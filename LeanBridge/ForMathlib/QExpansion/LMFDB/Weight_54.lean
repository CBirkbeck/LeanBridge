/-- Minimal polynomial of α (degree 4) as `Polynomial ℂ`. -/
noncomputable def α_54_minpoly : Polynomial ℂ :=
  Polynomial.X ^ 4 +
    Polynomial.C 39446133467662904714689328971776 +
    Polynomial.C (-1083312724663489297121280) * Polynomial.X +
    Polynomial.C (-19584715019010048) * Polynomial.X ^ 2 +
    Polynomial.C 68476320 * Polynomial.X ^ 3

lemma α_54_minpoly_natDegree : α_54_minpoly.natDegree = 4 := by
  unfold α_54_minpoly
  compute_degree!

lemma α_54_minpoly_degree_ne_zero : α_54_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_54_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_54_minpoly_natDegree]
  decide

/-- α is some root of the degree-4 minimal polynomial in ℂ. -/
noncomputable def α_54 : ℂ :=
  (IsAlgClosed.exists_root α_54_minpoly α_54_minpoly_degree_ne_zero).choose

lemma α_54_isRoot : Polynomial.IsRoot α_54_minpoly α_54 :=
  (IsAlgClosed.exists_root α_54_minpoly α_54_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_54_is_root :
    α_54 ^ 4 +
      39446133467662904714689328971776 +
      (-1083312724663489297121280) * α_54 +
      (-19584715019010048) * α_54 ^ 2 +
      68476320 * α_54 ^ 3 = 0 := by
  have h := α_54_isRoot
  unfold Polynomial.IsRoot α_54_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


