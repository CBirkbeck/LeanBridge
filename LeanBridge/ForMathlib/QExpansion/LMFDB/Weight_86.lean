    Polynomial.C 25777042732431769711558332265361302177218232143229983587617996800 * Polynomial.X +
    Polynomial.C 6762034528787600549896548602635210390056501245902848 * Polynomial.X ^ 2 +
    Polynomial.C (-718682363872979487719506400535537254400) * Polynomial.X ^ 3 +
    Polynomial.C (-180083699101345331242893312) * Polynomial.X ^ 4 +
    Polynomial.C 3596910688800 * Polynomial.X ^ 5

lemma α_86_minpoly_natDegree : α_86_minpoly.natDegree = 6 := by
  unfold α_86_minpoly
  compute_degree!

lemma α_86_minpoly_degree_ne_zero : α_86_minpoly.degree ≠ 0 := by
  rw [Polynomial.degree_eq_natDegree (fun h => by
    have := α_86_minpoly_natDegree
    rw [h, Polynomial.natDegree_zero] at this
    exact absurd this (by decide))]
  rw [α_86_minpoly_natDegree]
  decide

/-- α is some root of the degree-6 minimal polynomial in ℂ. -/
noncomputable def α_86 : ℂ :=
  (IsAlgClosed.exists_root α_86_minpoly α_86_minpoly_degree_ne_zero).choose

lemma α_86_isRoot : Polynomial.IsRoot α_86_minpoly α_86 :=
  (IsAlgClosed.exists_root α_86_minpoly α_86_minpoly_degree_ne_zero).choose_spec

/-- Explicit polynomial relation: minpoly evaluated at α is zero. -/
lemma α_86_is_root :
    α_86 ^ 6 +
      (-651453564182627074233502499539063680566772829640480606321381488113393598464) +
      25777042732431769711558332265361302177218232143229983587617996800 * α_86 +
      6762034528787600549896548602635210390056501245902848 * α_86 ^ 2 +
      (-718682363872979487719506400535537254400) * α_86 ^ 3 +
      (-180083699101345331242893312) * α_86 ^ 4 +
      3596910688800 * α_86 ^ 5 = 0 := by
  have h := α_86_isRoot
  unfold Polynomial.IsRoot α_86_minpoly at h
  simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
    Polynomial.eval_C, Polynomial.eval_X] at h
  linear_combination h


