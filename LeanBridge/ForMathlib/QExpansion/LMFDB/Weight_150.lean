/-! ## Uniqueness theorem -/


/-- **Uniqueness theorem.** Any level-1 weight-150 modular form `f` whose first 13
q-coefficients match the LMFDB-published values for `1.150.a.{a..}` is equal to our
explicit construction `lmfdb_1_150_a_orbit`. Proven via `ModularForm.eq_of_sturm_bound`. -/
theorem identifies_lmfdb_1_150_a_orbit (f : ModularForm 𝒮ℒ 150)
    (h_0 : (PowerSeries.coeff (R := ℂ) 0) (qExpansion 1 (f : ℍ → ℂ)) = 0)
    (h_1 : (PowerSeries.coeff (R := ℂ) 1) (qExpansion 1 (f : ℍ → ℂ)) = 1)
    (h_2 : (PowerSeries.coeff (R := ℂ) 2) (qExpansion 1 (f : ℍ → ℂ)) = 1 * α_150)
    (h_3 : (PowerSeries.coeff (R := ℂ) 3) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ( / ) * α_150 + ( / ) * α_150 ^ 2 + ((-( / ))) * α_150 ^ 3 + ((-( / ))) * α_150 ^ 4 + ( / ) * α_150 ^ 5 + ( / ) * α_150 ^ 6 + ((-( / ))) * α_150 ^ 7 + ((-( / ))) * α_150 ^ 8 + ( / ) * α_150 ^ 9 + ( / ) * α_150 ^ 10 + ((-( / ))) * α_150 ^ 11)
    (h_4 : (PowerSeries.coeff (R := ℂ) 4) (qExpansion 1 (f : ℍ → ℂ)) = (-713623846352979940529142984724747568191373312) + 1 * α_150 ^ 2)
    (h_5 : (PowerSeries.coeff (R := ℂ) 5) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ((-( / ))) * α_150 + ( / ) * α_150 ^ 2 + ( / ) * α_150 ^ 3 + ((-( / ))) * α_150 ^ 4 + ((-( / ))) * α_150 ^ 5 + ( / ) * α_150 ^ 6 + ( / ) * α_150 ^ 7 + ((-( / ))) * α_150 ^ 8 + ((-( / ))) * α_150 ^ 9 + ( / ) * α_150 ^ 10 + ((-( / ))) * α_150 ^ 11)
    (h_6 : (PowerSeries.coeff (R := ℂ) 6) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ( / ) * α_150 + ((-( / ))) * α_150 ^ 2 + ((-( / ))) * α_150 ^ 3 + ( / ) * α_150 ^ 4 + ( / ) * α_150 ^ 5 + ((-( / ))) * α_150 ^ 6 + ( / ) * α_150 ^ 7 + ( / ) * α_150 ^ 8 + ((-( / ))) * α_150 ^ 9 + ((-( / ))) * α_150 ^ 10 + ( / ) * α_150 ^ 11)
    (h_7 : (PowerSeries.coeff (R := ℂ) 7) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ((-( / ))) * α_150 + ( / ) * α_150 ^ 2 + ( / ) * α_150 ^ 3 + ((-( / ))) * α_150 ^ 4 + ((-( / ))) * α_150 ^ 5 + ( / ) * α_150 ^ 6 + ((-( / ))) * α_150 ^ 7 + ((-( / ))) * α_150 ^ 8 + ( / ) * α_150 ^ 9 + ( / ) * α_150 ^ 10 + ((-( / ))) * α_150 ^ 11)
    (h_8 : (PowerSeries.coeff (R := ℂ) 8) (qExpansion 1 (f : ℍ → ℂ)) = (-1427247692705959881058285969449495136382746624) * α_150 + 1 * α_150 ^ 3)
    (h_9 : (PowerSeries.coeff (R := ℂ) 9) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ((-( / ))) * α_150 + ((-( / ))) * α_150 ^ 2 + ( / ) * α_150 ^ 3 + ( / ) * α_150 ^ 4 + ((-( / ))) * α_150 ^ 5 + ((-( / ))) * α_150 ^ 6 + ( / ) * α_150 ^ 7 + ( / ) * α_150 ^ 8 + ((-( / ))) * α_150 ^ 9 + ((-( / ))) * α_150 ^ 10 + ( / ) * α_150 ^ 11)
    (h_10 : (PowerSeries.coeff (R := ℂ) 10) (qExpansion 1 (f : ℍ → ℂ)) = ( / ) + ((-( / ))) * α_150 + ((-( / ))) * α_150 ^ 2 + ( / ) * α_150 ^ 3 + ( / ) * α_150 ^ 4 + ((-( / ))) * α_150 ^ 5 + ((-( / ))) * α_150 ^ 6 + ( / ) * α_150 ^ 7 + ( / ) * α_150 ^ 8 + ((-( / ))) * α_150 ^ 9 + ((-( / ))) * α_150 ^ 10 + ( / ) * α_150 ^ 11)
    (h_11 : (PowerSeries.coeff (R := ℂ) 11) (qExpansion 1 (f : ℍ → ℂ)) = ((-( / ))) + ((-( / ))) * α_150 + ( / ) * α_150 ^ 2 + ( / ) * α_150 ^ 3 + ((-( / ))) * α_150 ^ 4 + ( / ) * α_150 ^ 5 + ( / ) * α_150 ^ 6 + ((-( / ))) * α_150 ^ 7 + ((-( / ))) * α_150 ^ 8 + ( / ) * α_150 ^ 9 + ( / ) * α_150 ^ 10 + ((-( / ))) * α_150 ^ 11)
